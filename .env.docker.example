# OpenClaw Docker Compose .env example
#
# Usage (on your VPS):
#   cp .env.docker.example .env
#   # edit values
#   docker compose -f docker-compose.yml -f docker-compose.vps.yml up -d openclaw-gateway
#
# Keep real secrets out of git.

# Image name (build locally on the VPS, or point to your registry image)
OPENCLAW_IMAGE=openclaw:local

# Host directories (persisted) mounted into the container at /home/node/.openclaw
OPENCLAW_CONFIG_DIR=/root/.openclaw
OPENCLAW_WORKSPACE_DIR=/root/.openclaw/workspace

# Gateway exposure
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_BIND=lan

# Gateway auth (required for public access)
OPENCLAW_GATEWAY_TOKEN=change-me-to-a-long-random-token

# Public access note:
# Dashboard URL becomes: http://<server-ip>:18789
# Ensure your cloud security group/firewall allows TCP 18789.

# Optional: model provider API keys (you can also store these in auth profiles via `openclaw onboard`)
# GMN_CODEX_API_KEY=sk-...
# TABCODE_API_KEY=sk-...

# Optional: Claude cookies (only if you use those providers)
# CLAUDE_AI_SESSION_KEY=
# CLAUDE_WEB_SESSION_KEY=
# CLAUDE_WEB_COOKIE=

# Optional docker-setup.sh knobs (if you use that script)
# OPENCLAW_DOCKER_APT_PACKAGES=
# OPENCLAW_EXTRA_MOUNTS=
# OPENCLAW_HOME_VOLUME=
